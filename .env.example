# UPS OAuth client credentials
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=

# REST API base (production: https://onlinetools.ups.com/api — CIE sandbox often https://wwwcie.ups.com/api)
UPS_API_BASE_URL=https://wwwcie.ups.com/api

# OAuth token URL (e.g. sandbox https://wwwcie.ups.com/security/v1/oauth/token)
UPS_OAUTH_TOKEN_URL=https://wwwcie.ups.com/security/v1/oauth/token

# UPS shipper account number (ShipperNumber)
UPS_SHIPPER_NUMBER=

# Rating API version (e.g. v2409)
UPS_RATING_VERSION=v2409

# HTTP timeout in milliseconds
REQUEST_TIMEOUT_MS=30000
